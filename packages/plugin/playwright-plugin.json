{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "args": [
        "--disable-features=DisableLoadExtensionCommandLineSwitch,DisableDisableExtensionsExceptCommandLineSwitch",
        "--disable-extensions-except=../../dist/extension",
        "--load-extension=../../dist/extension"
      ]
    },
    "userDataDir": ".playwright-cli/profiles/playwright-plugin"
  },
  "allowUnrestrictedFileAccess": true
}
